<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 卡片容器 -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_miniapp_item_rounded">

        <!-- 小程序图标 -->
        <ImageView
            android:id="@+id/miniapp_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_miniapp" />

        <!-- 状态徽标：运行中（右上）-->
        <TextView
            android:id="@+id/tv_support_scene"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="@drawable/bg_badge_gray"
            android:gravity="center"
            android:text="In"
            android:textSize="8sp"
            android:textColor="#FFFFFF"/>

        <!-- 自动加载（右下）-->
        <TextView
            android:id="@+id/tv_autoload"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="4dp"
            android:background="@drawable/bg_badge_green"
            android:gravity="center"
            android:text="A"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 小程序名称 -->
    <TextView
        android:id="@+id/miniapp_title"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#000000"
        android:textSize="12sp" />

</LinearLayout>